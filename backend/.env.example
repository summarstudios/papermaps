# Database
DATABASE_URL="postgresql://user:password@localhost:5432/summer_studios"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Redis (for BullMQ)
REDIS_URL="redis://localhost:6379"

# Server
PORT=3001
NODE_ENV="development"
LOG_LEVEL="info"

# CORS
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"

# Frontend
FRONTEND_URL="http://localhost:3000"

# Scraping
SCRAPE_DELAY_MS=3000
SCRAPE_MAX_REQUESTS_PER_MINUTE=10

# Perplexity AI (optional - for AI-powered business enrichment)
PERPLEXITY_API_KEY=""

# Google Places API (optional - for Google Places discovery)
GOOGLE_PLACES_API_KEY=""
GOOGLE_PLACES_SEARCH_RADIUS=2000
