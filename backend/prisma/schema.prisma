generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  SALES_REP
}

enum LeadStage {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum LeadPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum LeadCategory {
  STARTUP
  RESTAURANT
  HOTEL
  ECOMMERCE
  SALON
  CLINIC
  GYM
  RETAIL
  EDUCATION
  REAL_ESTATE
  AGENCY
  OTHER
}

enum LeadSource {
  GOOGLE_SEARCH
  GOOGLE_MAPS
  GOOGLE_PLACES
  WEBSITE_CONTACT
  REFERRAL
  MANUAL
  PERPLEXITY
}

enum LeadType {
  NO_WEBSITE
  OUTDATED_WEBSITE
  CONTACT_FORM
  REFERRAL
  MANUAL
}

enum ActivityType {
  NOTE
  CALL
  EMAIL
  MEETING
  TASK
}

enum ScrapeJobType {
  GOOGLE_SEARCH
  GOOGLE_MAPS
  PERPLEXITY
  DISCOVERY_PIPELINE
}

enum ScrapeJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum ProspectStatus {
  PROSPECT        // Raw scraped business, awaiting review
  LEAD            // Promoted to sales pipeline
  NOT_INTERESTED  // Reviewed and rejected
  ARCHIVED        // Soft deleted / hidden
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(SALES_REP)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  leads         Lead[]
  activities    Activity[]
  scrapeJobs    ScrapeJob[]
  promotedLeads Lead[]     @relation("PromotedLeads")

  @@map("users")
}

model Lead {
  id            String       @id @default(cuid())
  googlePlaceId String?      @unique // For deduplication with Google Places API
  businessName  String
  contactPerson String?
  email         String?
  phone         String?
  website       String?
  address       String?
  city          String?
  state         String?
  locality      String?      // Neighborhood/area within city
  country       String       @default("India")
  latitude      Float?
  longitude     Float?
  category      LeadCategory @default(OTHER)
  stage         LeadStage    @default(NEW)
  priority      LeadPriority @default(MEDIUM)
  score         Int          @default(0) // 0-100
  source        LeadSource   @default(MANUAL)
  leadType      LeadType     @default(MANUAL)

  // Website analysis
  hasWebsite           Boolean @default(false)
  lighthouseScore      Int? // Performance score 0-100
  lighthouseSeo        Int? // SEO score 0-100
  lighthouseAccessibility Int?
  lighthouseBestPractices Int?
  websiteNeedsRedesign Boolean @default(false)

  // AI analysis
  perplexityAnalysis String? @db.Text
  salesIntelligence  Json?   // Structured deep research data (decision makers, company info, pain points, etc.)
  qualificationError String? // Error message if Lighthouse/qualification failed

  // Contact status
  emailVerified     Boolean   @default(false)
  lastContactedAt   DateTime?
  nextFollowUpAt    DateTime?

  // Notes
  notes String? @db.Text

  // Prospect management
  prospectStatus      ProspectStatus @default(PROSPECT)
  promotedAt          DateTime?      // When promoted from PROSPECT to LEAD
  promotedById        String?        // Who promoted it
  reviewedAt          DateTime?      // When last reviewed
  notInterestedReason String?        // Optional reason for NOT_INTERESTED

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  assignedToId String?
  assignedTo   User?      @relation(fields: [assignedToId], references: [id])
  promotedBy   User?      @relation("PromotedLeads", fields: [promotedById], references: [id])
  activities   Activity[]
  tags         TagOnLead[]
  scrapeJobId  String?
  scrapeJob    ScrapeJob? @relation(fields: [scrapeJobId], references: [id])

  @@index([stage])
  @@index([category])
  @@index([score])
  @@index([assignedToId])
  @@index([city, state])
  @@index([prospectStatus])
  @@index([prospectStatus, createdAt])
  @@index([prospectStatus, scrapeJobId])
  @@map("leads")
}

model Tag {
  id        String      @id @default(cuid())
  name      String      @unique
  color     String      @default("#6366f1") // Indigo
  createdAt DateTime    @default(now())
  leads     TagOnLead[]

  @@map("tags")
}

model TagOnLead {
  leadId    String
  tagId     String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([leadId, tagId])
  @@map("tags_on_leads")
}

model Activity {
  id          String       @id @default(cuid())
  type        ActivityType
  title       String
  description String?      @db.Text
  outcome     String?
  scheduledAt DateTime?
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Relations
  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@index([leadId])
  @@index([type])
  @@map("activities")
}

model ScrapingRegion {
  id        String   @id @default(cuid())
  name      String   @unique
  cities    String[] // Array of city names
  state     String?
  country   String   @default("India")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  scrapeJobs ScrapeJob[]

  @@map("scraping_regions")
}

model ScrapeJob {
  id       String          @id @default(cuid())
  type     ScrapeJobType
  query    String
  location String?
  category LeadCategory?
  status   ScrapeJobStatus @default(PENDING)

  // Results
  leadsFound     Int @default(0)
  leadsCreated   Int @default(0)
  leadsDuplicate Int @default(0)
  leadsSkipped   Int @default(0) // Businesses skipped because they have good websites

  // Error tracking
  errorMessage String? @db.Text
  errorStack   String? @db.Text

  // Timing
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  regionId    String?
  region      ScrapingRegion? @relation(fields: [regionId], references: [id])
  createdById String
  createdBy   User            @relation(fields: [createdById], references: [id])
  leads       Lead[]
  apiCallLogs ApiCallLog[]
  zoneScrapeHistory ZoneScrapeHistory[]

  @@index([status])
  @@index([type])
  @@map("scrape_jobs")
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("settings")
}

enum ContactStatus {
  NEW
  READ
  REPLIED
  ARCHIVED
}

model ContactSubmission {
  id        String        @id @default(cuid())
  name      String
  email     String
  company   String?
  phone     String?
  service   String?
  budget    String?
  message   String        @db.Text
  status    ContactStatus @default(NEW)
  notes     String?       @db.Text
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("contact_submissions")
}

// API Call Logging for cost tracking
enum ApiProvider {
  GOOGLE_PLACES
  PERPLEXITY
  GOOGLE_MAPS
  LIGHTHOUSE
}

model ApiCallLog {
  id            String      @id @default(cuid())
  provider      ApiProvider
  endpoint      String
  method        String      // GET, POST
  statusCode    Int
  responseTimeMs Int
  success       Boolean
  error         String?     @db.Text
  metadata      String?     @db.Text // JSON string
  estimatedCost Float?      @default(0)

  // Link to scrape job if applicable
  scrapeJobId   String?
  scrapeJob     ScrapeJob?  @relation(fields: [scrapeJobId], references: [id], onDelete: SetNull)

  createdAt     DateTime    @default(now())

  @@index([provider])
  @@index([scrapeJobId])
  @@index([createdAt])
  @@map("api_call_logs")
}

// Track which zones have been scraped for each business type
// This allows the scraper to skip already-scraped zones and find new leads
model ZoneScrapeHistory {
  id           String   @id @default(cuid())
  city         String   // e.g., "Bangalore"
  zoneName     String   // e.g., "Koramangala"
  businessType String   // e.g., "gym", "salon", "clinic"
  leadsFound   Int      @default(0)
  scrapedAt    DateTime @default(now())

  // Link to scrape job
  scrapeJobId  String?
  scrapeJob    ScrapeJob? @relation(fields: [scrapeJobId], references: [id], onDelete: SetNull)

  @@unique([city, zoneName, businessType]) // One record per zone+businessType combo
  @@index([city, businessType])
  @@index([scrapedAt])
  @@map("zone_scrape_history")
}
